JMETER_HOME=D:\Jmeter\apache-jmeter-5.5
DATA_ROOT=D:\JmeterAgent-Server\data
# Relative SQLite URLs are resolved to an absolute path under backend/
# so updates / different working directories never create a second empty database.
DATABASE_URL=sqlite:///./jmeter_agent.db
HOST=0.0.0.0
PORT=8080
METRICS_BUCKET_SECONDS=5
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Required for Report Bug (opens GitHub Issues + uploads logs/screenshots).
# Create a classic PAT with `repo` scope: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=nareshnakka/JmeterSolution

    # Azure Monitor — CPU/Memory for target VMs (stored with each test run only).
    # Preferred: sign in on the Azure page (device code; token cache encrypted with DPAPI).
    # Auth modes for .env fallback:
    #   interactive = prefer Azure page sign-in / CLI
    #   cli           = use `az login` on this machine
    #   client_secret = App Registration (needs Monitoring Reader from admin)
    AZURE_AUTH_MODE=interactive
    AZURE_TENANT_ID=
    AZURE_CLIENT_ID=
    AZURE_CLIENT_SECRET=
    AZURE_SUBSCRIPTION_ID=
